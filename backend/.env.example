# Copy this file to .env in the backend/ folder and fill in your credentials.
#
# This pipeline uses Cloudflare Workers AI (Llama 3.2 11B Vision) alongside
# local YOLOv8 object detection — it no longer calls Groq/Llama text models,
# so GROQ_API_KEY is not required here.
#
# Get Cloudflare credentials at https://dash.cloudflare.com/ → Workers AI
# (Account ID is on the right sidebar of your dashboard; create an API token
# with "Workers AI" permissions for the auth token).
CLOOUDFLARE_TOKEN=YOUR_TOKEN_HERE
OPENAI_API_KEY=YOUR_KEY_HERE
